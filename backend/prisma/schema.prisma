generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TemperatureCReading {
  id             String    @id @default(cuid())
  value          Float
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([createdAt])
  @@map("temperature_c_readings")
}

model HumidityReading {
  id             String    @id @default(cuid())
  value          Float
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([createdAt])
  @@map("humidity_readings")
}

model GasReading {
  id             String    @id @default(cuid())
  value          Float
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([createdAt])
  @@map("gas_readings")
}
